    "better-echarts-maps": "^0.0.3",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "dayjs": "^1.11.20",
    "echarts": "^6.0.0",
    "element-plus": "^2.13.7",
    "lunar-javascript": "^1.7.7",
    "pinia": "^3.0.4",
    "vue": "^3.5.26",
    "vue-echarts": "^8.0.1",
    "vue-router": "^4.6.4",
    "vuedraggable": "^4.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@tsconfig/node24": "^24.0.3",
