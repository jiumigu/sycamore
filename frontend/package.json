    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.2",
    "eslint-plugin-oxlint": "~1.38.0",
    "eslint-plugin-playwright": "^2.4.0",
    "eslint-plugin-vue": "~10.6.2",
    "jiti": "^2.6.1",
    "npm-run-all2": "^8.0.4",
    "oxlint": "~1.38.0",
    "prettier": "3.7.4",
    "sass": "^1.97.3",
    "sass-loader": "^14.2.1",
    "typescript": "~5.9.3",
    "vite": "^7.3.0",
    "vite-plugin-vue-devtools": "^8.0.5",
    "vue-tsc": "^3.2.2"
